@page "/medidas-cabello"
@attribute [Authorize(Policy = "TenantMember")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using CubotNails.Application.Tenancy
@inject IHairLengthService Svc
@inject IJSRuntime JS
@inject IWebHostEnvironment Env

<PageTitle>Medidas de cabello - CUBOT.nails</PageTitle>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M3 12h18"/><path d="M3 18h18"/></svg>
            </div>
            <span>Configuracion del salon</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Medidas de cabello</h1>
        <p class="page-sub" style="margin-bottom:0;">Define tu escala de largo y sube fotos de referencia de cada medida. Esas fotos le ensenan a la IA a reconocer el largo del cabello de una clienta.</p>
    </div>
    <button class="btn btn-primary" @onclick="() => OpenForm(null)">+ Nueva medida</button>
</div>

@if (_loading)
{
    <p><em>Cargando...</em></p>
}
else if (_items.Count == 0)
{
    <p class="text-muted">Aun no defines medidas de cabello. Crea la primera con "+ Nueva medida" (ej. Corto, Medio, Largo, Muy largo) y sube fotos de referencia.</p>
}
else
{
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:16px;">
        @foreach (var c in _items)
        {
            <div class="card" style="padding:16px;display:flex;flex-direction:column;gap:10px;@(c.IsActive ? "" : "opacity:.65;")">
                <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px;">
                    <div style="font-weight:800;font-size:15px;min-width:0;">@c.Name</div>
                    <span style="flex:none;font-size:11px;font-weight:700;padding:2px 9px;border-radius:999px;@(c.IsActive ? "background:#10b98122;color:#10b981;" : "background:var(--muted);color:var(--muted-foreground);")">@(c.IsActive ? "Activa" : "Inactiva")</span>
                </div>
                @if (!string.IsNullOrWhiteSpace(c.Description))
                {
                    <div class="text-muted" style="font-size:12px;">@c.Description</div>
                }

                <div>
                    <div class="text-muted" style="font-size:11px;text-transform:uppercase;letter-spacing:.04em;margin-bottom:6px;">Fotos de referencia (@c.Images.Count)</div>
                    <div style="display:flex;flex-wrap:wrap;gap:8px;">
                        @foreach (var img in c.Images)
                        {
                            <div style="position:relative;width:74px;height:74px;border-radius:10px;overflow:hidden;border:1px solid var(--border);">
                                <img src="@img.Url" alt="@img.FileName" style="width:100%;height:100%;object-fit:cover;" />
                                <button type="button" title="Quitar" @onclick="() => RemoveImageAsync(img.Id)" disabled="@_busy"
                                        style="position:absolute;top:2px;right:2px;width:20px;height:20px;border-radius:50%;border:none;background:rgba(0,0,0,.6);color:#fff;cursor:pointer;line-height:1;">&times;</button>
                            </div>
                        }
                        <label style="width:74px;height:74px;border-radius:10px;border:1px dashed var(--border);display:grid;place-items:center;cursor:pointer;color:var(--muted-foreground);font-size:11px;text-align:center;">
                            + Foto
                            <InputFile OnChange="@(e => OnImagesSelectedAsync(e, c.Id))" accept="image/*" multiple style="display:none;" />
                        </label>
                    </div>
                    @if (_imgMsgFor == c.Id && _imgMsg is not null) { <div class="text-muted small" style="margin-top:4px;">@_imgMsg</div> }
                </div>

                <div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:auto;padding-top:4px;">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenForm(c)">Editar</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleActiveAsync(c)" disabled="@_busy">@(c.IsActive ? "Desactivar" : "Activar")</button>
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(c)" disabled="@_busy" title="Eliminar medida">&times;</button>
                </div>
            </div>
        }
    </div>
}

@if (_formOpen)
{
    <div class="modal-overlay">
        <div class="modal-dialog" style="max-width:460px;">
            <div class="modal-head">
                <h3>@(_editingId is null ? "Nueva medida" : "Editar medida")</h3>
                <button class="modal-close" @onclick="() => _formOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field">
                    <label class="form-label">Nombre *</label>
                    <input class="form-control" @bind="_fName" placeholder="Corto, Medio, Largo, Muy largo..." />
                </div>
                <div class="field">
                    <label class="form-label">Descripcion (referencia para la IA)</label>
                    <textarea class="form-control" rows="3" @bind="_fDescription" placeholder="Ej. El cabello llega hasta los hombros / debajo de la cintura..."></textarea>
                </div>
                @if (_error is not null)
                {
                    <div class="text-danger small">@_error</div>
                }
                <div class="text-muted" style="font-size:11.5px;">Despues de crear la medida podras subir las fotos de referencia desde su tarjeta.</div>
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _formOpen = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_fName))">Guardar</button>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private bool _busy;
    private bool _formOpen;
    private string? _error;
    private Guid? _editingId;
    private string _fName = "";
    private string? _fDescription;
    private string? _imgMsg;
    private Guid? _imgMsgFor;
    private List<HairLengthCategoryDto> _items = new();

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _items = (await Svc.ListAsync(includeInactive: true)).ToList();
        _loading = false;
    }

    private void OpenForm(HairLengthCategoryDto? c)
    {
        _error = null;
        _editingId = c?.Id;
        _fName = c?.Name ?? "";
        _fDescription = c?.Description;
        _formOpen = true;
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_fName)) { _error = "Escribe el nombre de la medida."; return; }
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            var req = new SaveHairLengthCategoryRequest(_fName, _fDescription);
            var result = _editingId is Guid id ? await Svc.UpdateCategoryAsync(id, req, actor) : await Svc.CreateCategoryAsync(req, actor);
            if (result is null) { _error = "No se pudo guardar."; return; }
            _formOpen = false;
            await ReloadAsync();
        }
        finally { _busy = false; }
    }

    private async Task ToggleActiveAsync(HairLengthCategoryDto c)
    {
        _busy = true;
        try { await Svc.SetActiveAsync(c.Id, !c.IsActive, await ActorAsync()); await ReloadAsync(); }
        finally { _busy = false; }
    }

    private async Task DeleteAsync(HairLengthCategoryDto c)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Eliminar la medida \"{c.Name}\" y sus fotos de referencia?")) { return; }
        _busy = true;
        try { await Svc.DeleteCategoryAsync(c.Id, await ActorAsync()); await ReloadAsync(); }
        finally { _busy = false; }
    }

    private async Task OnImagesSelectedAsync(InputFileChangeEventArgs e, Guid categoryId)
    {
        _busy = true; _imgMsg = null; _imgMsgFor = categoryId;
        try
        {
            var actor = await ActorAsync();
            foreach (var file in e.GetMultipleFiles(8))
            {
                var saved = await SaveImageFileAsync(file);
                if (saved is null) { _imgMsg = "Alguna imagen no se pudo subir (max 10MB)."; continue; }
                await Svc.AddImageAsync(categoryId, saved.Value.Url, saved.Value.Name, actor);
            }
            await ReloadAsync();
        }
        finally { _busy = false; }
    }

    private async Task RemoveImageAsync(Guid imageId)
    {
        _busy = true;
        try { await Svc.RemoveImageAsync(imageId, await ActorAsync()); await ReloadAsync(); }
        finally { _busy = false; }
    }

    private async Task<(string Url, string Name)?> SaveImageFileAsync(IBrowserFile file)
    {
        const long max = 10L * 1024 * 1024;
        if (file.Size <= 0 || file.Size > max) { return null; }
        using var ms = new MemoryStream();
        await file.OpenReadStream(max).CopyToAsync(ms);
        var ext = System.IO.Path.GetExtension(file.Name);
        var dir = System.IO.Path.Combine(Env.WebRootPath, "uploads", "hair");
        System.IO.Directory.CreateDirectory(dir);
        var name = $"hair-{Guid.NewGuid():N}{ext}";
        await System.IO.File.WriteAllBytesAsync(System.IO.Path.Combine(dir, name), ms.ToArray());
        return ($"/uploads/hair/{name}", file.Name);
    }

    private async Task<Guid> ActorAsync()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }
}
